{
  "expo": {
    "name": "Photo Journal",
    "slug": "photo-journal",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EFE4"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.mey.photojournal",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5EFE4"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Photo Journal butuh akses galeri untuk memilih foto momen harianmu.",
          "cameraPermission": "Photo Journal butuh akses kamera untuk mengambil foto momen harianmu."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Photo Journal butuh akses lokasi untuk menandai tempat dan menampilkan cuaca saat itu."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "26847468-b780-446d-85fa-8965a6c38d07"
      }
    },
    "owner": "maengie"
  }
}
